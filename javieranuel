<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Javier Anuel // Portafolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        /* ============================================================
           // PORTAFOLIO DE JAVIER ANUEL
           // Paleta: Cyber-Cyberpunk Sofisticado (Semi-Dark)
           // Fondo: #181824 | Acento: #FF007F | Soporte: #8A2BE2
           // ============================================================ */

        /* === RESET Y CONFIGURACIÓN BASE === */
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #181824;
            --bg-card: #1c1c2b;
            --bg-card-hover: #222236;
            --border-subtle: #2a2a3a;
            --accent-fuchsia: #FF007F;
            --accent-purple: #8A2BE2;
            --text-primary: #F8F9FA;
            --text-secondary: #6C757D;
            --font-main: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
            --transition-smooth: all 0.3s ease;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-main);
            background-color: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* === SCROLLBAR PERSONALIZADA === */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-primary);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--border-subtle);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: var(--accent-fuchsia);
        }

        /* === UTILIDADES === */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .section-title {
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 12px;
            letter-spacing: -0.5px;
        }

        .section-subtitle {
            color: var(--text-secondary);
            font-size: 1rem;
            margin-bottom: 48px;
            font-family: var(--font-mono);
        }

        /* === HEADER / NAV === */
        header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            background: rgba(24, 24, 36, 0.92);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-subtle);
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 18px 24px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .logo {
            font-family: var(--font-mono);
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--text-primary);
            text-decoration: none;
            letter-spacing: 1px;
        }

        .logo span {
            color: var(--accent-fuchsia);
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 32px;
            list-style: none;
        }

        .nav-links a {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            transition: var(--transition-smooth);
            position: relative;
        }

        .nav-links a:hover {
            color: var(--accent-fuchsia);
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--accent-fuchsia);
            transition: var(--transition-smooth);
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        .btn-cv-nav {
            padding: 8px 18px;
            border: 1.5px solid var(--accent-fuchsia);
            color: var(--accent-fuchsia);
            background: transparent;
            font-family: var(--font-main);
            font-size: 0.85rem;
            font-weight: 600;
            border-radius: 6px;
            cursor: pointer;
            text-decoration: none;
            transition: var(--transition-smooth);
        }

        .btn-cv-nav:hover {
            background: var(--accent-fuchsia);
            color: var(--text-primary);
            box-shadow: 0 0 20px rgba(255, 0, 127, 0.35);
        }

        .mobile-menu-btn {
            display: none;
            background: none;
            border: none;
            color: var(--text-primary);
            font-size: 1.5rem;
            cursor: pointer;
        }

        /* === HERO SECTION === */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 120px 24px 80px;
            position: relative;
            overflow: hidden;
        }

        .hero-bg-img {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: url('https://images.stockcake.com/public/4/d/b/4db5494a9aa7930b576f299c1525f0826c1420ef.jpg');
            background-size: cover;
            background-position: center;
            opacity: 0.15;
            z-index: 0;
        }

        .hero::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(180deg, rgba(24,24,36,0.7) 0%, rgba(24,24,36,0.95) 100%);
            z-index: 1;
        }

        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 800px;
        }

        .hero-avatar {
            width: 160px;
            height: 160px;
            border-radius: 20px;
            border: 3px solid var(--accent-fuchsia);
            margin: 0 auto 28px;
            overflow: hidden;
            position: relative;
            box-shadow: 0 0 30px rgba(255, 0, 127, 0.25), 0 0 60px rgba(138, 43, 226, 0.15);
            transition: var(--transition-smooth);
        }

        .hero-avatar:hover {
            transform: scale(1.05) rotate(2deg);
            box-shadow: 0 0 40px rgba(255, 0, 127, 0.4), 0 0 80px rgba(138, 43, 226, 0.25);
        }

        .hero-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .avatar-badge {
            position: absolute;
            bottom: -8px;
            right: -8px;
            background: var(--accent-fuchsia);
            color: var(--text-primary);
            font-family: var(--font-mono);
            font-size: 0.65rem;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 6px;
            border: 2px solid var(--bg-primary);
        }

        .hero-greeting {
            font-family: var(--font-mono);
            color: var(--accent-fuchsia);
            font-size: 0.9rem;
            margin-bottom: 16px;
            letter-spacing: 2px;
        }

        .hero-title {
            font-size: clamp(2.5rem, 6vw, 4.5rem);
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 16px;
            letter-spacing: -1.5px;
        }

        .hero-subtitle {
            font-size: clamp(1.1rem, 2.5vw, 1.5rem);
            font-weight: 400;
            color: var(--text-secondary);
            margin-bottom: 20px;
        }

        .hero-subtitle .typing-cursor {
            color: var(--accent-fuchsia);
            animation: blink 1s step-end infinite;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }

        .hero-statement {
            font-size: 1.05rem;
            color: var(--text-secondary);
            max-width: 600px;
            margin: 0 auto 40px;
            line-height: 1.7;
        }

        .btn-cta {
            display: inline-block;
            padding: 16px 40px;
            background: var(--accent-fuchsia);
            color: var(--text-primary);
            font-family: var(--font-main);
            font-size: 1rem;
            font-weight: 700;
            border: none;
            border-radius: 8px;
            text-decoration: none;
            cursor: pointer;
            transition: var(--transition-smooth);
            letter-spacing: 0.5px;
        }

        .btn-cta:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 30px rgba(255, 0, 127, 0.45), 0 0 60px rgba(255, 0, 127, 0.15);
        }

        /* === SOBRE MÍ & ENFOQUE === */
        .about {
            padding: 100px 0;
            background: linear-gradient(180deg, var(--bg-primary) 0%, rgba(28, 28, 43, 0.5) 100%);
            position: relative;
            overflow: hidden;
        }

        .about-bg-img {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: url('https://img.freepik.com/free-photo/acdabe501074d170361682be10bb8984e05b1f32.jpg');
            background-size: cover;
            background-position: center;
            opacity: 0.06;
            z-index: 0;
        }

        .about .container {
            position: relative;
            z-index: 1;
        }

        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: start;
        }

        .about-left h2 {
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 24px;
            letter-spacing: -0.5px;
        }

        .about-left p {
            color: var(--text-secondary);
            margin-bottom: 20px;
            line-height: 1.8;
            font-size: 1rem;
        }

        .about-left .highlight {
            color: var(--accent-fuchsia);
            font-weight: 600;
        }

        .interests-card {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 16px;
            padding: 36px;
            position: relative;
            overflow: hidden;
        }

        .interests-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--accent-fuchsia), var(--accent-purple));
        }

        .interests-card h3 {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .interests-card .code-comment {
            font-family: var(--font-mono);
            color: var(--text-secondary);
            font-size: 0.8rem;
            margin-bottom: 28px;
        }

        .interest-group {
            margin-bottom: 24px;
        }

        .interest-group:last-child {
            margin-bottom: 0;
        }

        .interest-label {
            font-family: var(--font-mono);
            font-size: 0.75rem;
            color: var(--accent-purple);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 10px;
            display: block;
        }

        .tag-container {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .tag {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 14px;
            background: rgba(255, 0, 127, 0.08);
            border: 1px solid rgba(255, 0, 127, 0.2);
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--text-primary);
            transition: var(--transition-smooth);
        }

        .tag:hover {
            background: rgba(255, 0, 127, 0.18);
            border-color: var(--accent-fuchsia);
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(255, 0, 127, 0.15);
        }

        .tag svg {
            width: 14px;
            height: 14px;
            opacity: 0.7;
        }

        .interests-image {
            width: 100%;
            height: 140px;
            object-fit: cover;
            border-radius: 10px;
            margin-bottom: 24px;
            opacity: 0.6;
            border: 1px solid var(--border-subtle);
            transition: var(--transition-smooth);
        }

        .interests-image:hover {
            opacity: 0.85;
            border-color: var(--accent-fuchsia);
        }

        /* === FORMACIÓN ACADÉMICA === */
        .education {
            padding: 100px 0;
            position: relative;
            overflow: hidden;
        }

        .education-bg-img {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: url('https://thumbs.dreamstime.com/b/dark-cyberpunk-neon-grid-background-pink-blue-glowing-lights-400228307.jpg');
            background-size: cover;
            background-position: center;
            opacity: 0.04;
            z-index: 0;
        }

        .education .container {
            position: relative;
            z-index: 1;
        }

        .timeline {
            position: relative;
            padding-left: 30px;
        }

        .timeline::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(180deg, var(--accent-fuchsia), var(--accent-purple));
        }

        .timeline-item {
            position: relative;
            padding-bottom: 40px;
        }

        .timeline-item:last-child {
            padding-bottom: 0;
        }

        .timeline-dot {
            position: absolute;
            left: -36px;
            top: 4px;
            width: 14px;
            height: 14px;
            background: var(--accent-fuchsia);
            border-radius: 50%;
            border: 3px solid var(--bg-primary);
            box-shadow: 0 0 10px rgba(255, 0, 127, 0.4);
        }

        .timeline-content {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 14px;
            padding: 28px 32px;
            transition: var(--transition-smooth);
        }

        .timeline-content:hover {
            border-color: rgba(255, 0, 127, 0.25);
            transform: translateX(6px);
        }

        .timeline-date {
            font-family: var(--font-mono);
            font-size: 0.8rem;
            color: var(--accent-fuchsia);
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .timeline-date .status-dot {
            width: 8px;
            height: 8px;
            background: #00c864;
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .timeline-title {
            font-size: 1.15rem;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .timeline-institution {
            color: var(--accent-purple);
            font-size: 0.95rem;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .timeline-desc {
            color: var(--text-secondary);
            font-size: 0.9rem;
            line-height: 1.6;
        }

        /* === CERTIFICACIONES === */
        .certifications {
            padding: 100px 0;
            background: linear-gradient(180deg, rgba(28, 28, 43, 0.5) 0%, var(--bg-primary) 100%);
        }

        .certs-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }

        .cert-card {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 14px;
            padding: 28px;
            transition: var(--transition-smooth);
            position: relative;
            overflow: hidden;
        }

        .cert-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: var(--border-subtle);
            transition: var(--transition-smooth);
        }

        .cert-card:hover {
            border-color: rgba(138, 43, 226, 0.3);
            transform: translateY(-4px);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.25);
        }

        .cert-card:hover::before {
            background: var(--accent-purple);
        }

        .cert-icon {
            width: 44px;
            height: 44px;
            background: rgba(138, 43, 226, 0.1);
            border: 1px solid rgba(138, 43, 226, 0.2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 16px;
        }

        .cert-icon svg {
            width: 22px;
            height: 22px;
            color: var(--accent-purple);
        }

        .cert-title {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .cert-org {
            font-family: var(--font-mono);
            font-size: 0.8rem;
            color: var(--accent-fuchsia);
            margin-bottom: 10px;
        }

        .cert-desc {
            color: var(--text-secondary);
            font-size: 0.85rem;
            line-height: 1.6;
        }

        /* === IDIOMAS === */
        .languages {
            padding: 80px 0;
            position: relative;
        }

        .lang-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
        }

        .lang-card {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 12px;
            padding: 24px;
            text-align: center;
            transition: var(--transition-smooth);
        }

        .lang-card:hover {
            border-color: rgba(255, 0, 127, 0.2);
            transform: translateY(-4px);
        }

        .lang-flag {
            font-size: 2rem;
            margin-bottom: 10px;
        }

        .lang-name {
            font-weight: 700;
            font-size: 1rem;
            margin-bottom: 4px;
        }

        .lang-level {
            font-family: var(--font-mono);
            font-size: 0.8rem;
            color: var(--text-secondary);
        }

        .lang-bar {
            width: 100%;
            height: 4px;
            background: var(--border-subtle);
            border-radius: 2px;
            margin-top: 12px;
            overflow: hidden;
        }

        .lang-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent-fuchsia), var(--accent-purple));
            border-radius: 2px;
            transition: width 1s ease;
        }

        /* === HABILIDADES (TECNOLOGÍAS) === */
        .skills {
            padding: 100px 0;
            position: relative;
            overflow: hidden;
        }

        .skills-bg-img {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: url('https://www.shutterstock.com/shutterstock/photos/2706910881/display_1500/stock-photo-programming-coding-lines-wallpaper-2706910881.jpg');
            background-size: cover;
            background-position: center;
            opacity: 0.04;
            z-index: 0;
        }

        .skills .container {
            position: relative;
            z-index: 1;
        }

        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 24px;
        }

        .skill-card {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 14px;
            padding: 36px 28px;
            transition: var(--transition-smooth);
            position: relative;
            overflow: hidden;
        }

        .skill-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: var(--border-subtle);
            transition: var(--transition-smooth);
        }

        .skill-card:hover {
            background: var(--bg-card-hover);
            transform: translateY(-6px);
            border-color: rgba(255, 0, 127, 0.3);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3), 0 0 30px rgba(255, 0, 127, 0.08);
        }

        .skill-card:hover::before {
            background: var(--accent-fuchsia);
            height: 3px;
        }

        .skill-icon {
            width: 52px;
            height: 52px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            background: rgba(255, 0, 127, 0.08);
            border: 1px solid rgba(255, 0, 127, 0.15);
        }

        .skill-icon svg {
            width: 28px;
            height: 28px;
        }

        .skill-card h3 {
            font-size: 1.15rem;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .skill-card p {
            color: var(--text-secondary);
            font-size: 0.9rem;
            line-height: 1.6;
        }

        .skill-status {
            display: inline-block;
            margin-top: 14px;
            padding: 4px 10px;
            border-radius: 4px;
            font-family: var(--font-mono);
            font-size: 0.7rem;
            font-weight: 500;
        }

        .status-active {
            background: rgba(0, 200, 100, 0.12);
            color: #00c864;
            border: 1px solid rgba(0, 200, 100, 0.2);
        }

        .status-progress {
            background: rgba(255, 193, 7, 0.12);
            color: #ffc107;
            border: 1px solid rgba(255, 193, 7, 0.2);
        }

        .skill-card.special {
            background: linear-gradient(135deg, var(--bg-card) 0%, rgba(138, 43, 226, 0.12) 100%);
            border: 1px solid rgba(138, 43, 226, 0.3);
        }

        .skill-card.special::before {
            background: linear-gradient(90deg, var(--accent-purple), var(--accent-fuchsia));
        }

        .skill-card.special:hover::before {
            background: linear-gradient(90deg, var(--accent-fuchsia), var(--accent-purple));
        }

        .skill-card.special .skill-icon {
            background: rgba(138, 43, 226, 0.12);
            border-color: rgba(138, 43, 226, 0.25);
        }

        .status-soon {
            background: rgba(138, 43, 226, 0.15);
            color: var(--accent-purple);
            border: 1px solid rgba(138, 43, 226, 0.25);
        }

        /* === PROYECTOS DESTACADOS === */
        .projects {
            padding: 100px 0;
            background: linear-gradient(180deg, rgba(28, 28, 43, 0.5) 0%, var(--bg-primary) 100%);
            position: relative;
            overflow: hidden;
        }

        .projects-bg-img {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: url('https://thumbs.dreamstime.com/b/cyberpunk-neon-wavy-abstract-background-futuristic-featuring-glowing-waveforms-purple-electric-blue-hot-pink-inspired-383314411.jpg');
            background-size: cover;
            background-position: center;
            opacity: 0.05;
            z-index: 0;
        }

        .projects .container {
            position: relative;
            z-index: 1;
        }

        .project-card {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 18px;
            overflow: hidden;
            transition: var(--transition-smooth);
        }

        .project-card:hover {
            border-color: rgba(255, 0, 127, 0.25);
